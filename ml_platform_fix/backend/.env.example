# 复制为 .env 后按需修改

# 默认 SQLite（开发）
DATABASE_URL=sqlite:///./data/ml_platform.db

# MySQL 示例（生产）
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/ml_platform?charset=utf8mb4

UPLOAD_DIR=./data/uploads
UPLOAD_MAX_BYTES=2147483648
MODELS_DIR=./data/models
PRISM_API_URL=http://127.0.0.1:5001
PRISM_MODEL_PATH=../../PRISM-main-api/output/PRISM_baby_small_lite.pt
PRISM_METRICS_PATH=./data/prism_metrics.json
BSAREC_ROOT=../../BSARec-main-api
BSAREC_MODEL_PATH=../../BSARec-main-api/src/output/BSARec_Job.pt

# 前端开发地址（CORS）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
